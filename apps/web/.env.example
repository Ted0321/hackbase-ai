DATABASE_URL="file:./prisma/dev.db"
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"

# Optional. Set to a stable value before public deployment.
# Used by docs and future share/export surfaces.
NEXT_PUBLIC_SITE_NAME="Prodia"

# Optional. Enables real LLM planning in `npm run pipeline:signals -- --planner llm`.
# Without this key, the LLM planner writes a dry-run prompt and falls back to deterministic planning.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Optional. Enables Google Gemini execution for the Findy DevOps AI Agent Hackathon evidence path.
# `npm run llm:pipeline:run-gemini` writes dry-run request artifacts without this key.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Optional for TLS environments where Node needs the OS certificate store.
NODE_OPTIONS="--use-system-ca"

# --- Product visual generation (DOC-105/DOC-106) --------------------------
# AI image generation for product showcases/icons is OFF by default. With none
# of these set, generation stays on the deterministic local SVG fallback and no
# paid image API is ever called. Enable per-kind ONLY when you intend to spend.
#
# Master switches (must be "true" to attempt AI generation):
PRODIA_VISUAL_AI_ENABLED=""        # Product Hunt style showcase image
PRODIA_ICON_AI_ENABLED=""          # Open-Launch style app icon
#
# Provider selection (default: local_svg). One of: local_svg|nano_banana|imagen|openai_images
# Production uses nano_banana for the showcase (see scripts/deploy-cloud-run.ts).
PRODIA_VISUAL_PROVIDER="local_svg"
PRODIA_ICON_PROVIDER="local_svg"
#
# Nano Banana Pro (gemini-3-pro-image): renders the exact title/tagline IN the image and
# rotates across 9 layout variants (thumbnail-variants.ts) — the production showcase path.
# Uses the existing GEMINI_API_KEY (no new secret); spend counts against GEMINI_DAILY_MAX_COST_USD.
PRODIA_NANO_BANANA_MODEL="gemini-3-pro-image"
PRODIA_NANO_BANANA_COST_USD="0.15"
PRODIA_NANO_BANANA_SIZE="2K"
#
# Imagen (legacy showcase path): draws a text-free illustration; the title is composited on
# top afterward (compose-thumbnail.ts). Kept as an alternative, not the default.
# Alternatives: imagen-4.0-fast-generate-001 (cheaper) / imagen-4.0-ultra-generate-001 (best text).
PRODIA_IMAGEN_MODEL="imagen-4.0-generate-001"
PRODIA_IMAGEN_COST_USD="0.04"
#
# Only if PRODIA_*_PROVIDER=openai_images (reuses OPENAI_API_KEY above):
OPENAI_IMAGE_MODEL="gpt-image-1"
#
# Cost/failure controls (Nano Banana Pro takes ~30-45s/image; raise the timeout for it):
PRODIA_VISUAL_TIMEOUT_MS="30000"
PRODIA_VISUAL_MAX_RETRIES="1"

# Public deployment checklist:
# - Use a persistent database instead of local SQLite for shared/public hosting.
# - Keep OPENAI_API_KEY server-side only; never expose it as NEXT_PUBLIC_*.
# - Decide whether generated artifacts remain local-only or are copied to durable storage.
# - Run `npm run verify` before publishing.
